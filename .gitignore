# ─────────────────────────────────────────────────────────────
# .gitignore — files Git should never track
# Standard Next.js + Firebase + editor setup
# ─────────────────────────────────────────────────────────────

# Dependencies — installed by `npm install`, should never be committed
node_modules/
.pnp
.pnp.js

# Next.js build output
.next/
out/
build/
dist/

# Production artifacts
*.tsbuildinfo
next-env.d.ts

# Logs
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# Runtime data
.DS_Store
*.pem

# Environment variables (keep secrets out of git)
.env
.env.local
.env.development.local
.env.test.local
.env.production.local

# Firebase
.firebase/
firebase-debug.log
firebase-debug.*.log
.firebaserc.local

# IDE / editor
.vscode/
.idea/
*.swp
*.swo

# OS
Thumbs.db
