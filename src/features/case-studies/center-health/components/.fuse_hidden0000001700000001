/*
 * OnboardingSection.module.css — Center Health (004)
 * Confirmed from Figma node 1161:5925 (updated layout).
 *
 * Index-left / content-right row pattern.
 * Content column holds: heading + body + whatBlock + image + results.
 */


/* ============================================================
   ROOT — outer section container
   Figma: flex-col, gap-0, py-96px, border-b #e5e7eb
   ============================================================ */

.root {
  display:        flex;
  flex-direction: column;
  padding-top:    var(--gap-64);
  padding-bottom: var(--gap-64);
  border-bottom:  1px solid var(--color-divider);
  width:          100%;
}


/* ============================================================
   ROW — index (left) + content (right)
   Figma: flex row, gap-48, items-start, w-full
   ============================================================ */

.row {
  display:     flex;
  align-items: flex-start;
  gap:         48px;
  width:       100%;
}


/* ============================================================
   INDEX — left column
   Figma: Inter 12px, #424242, uppercase, shrink-0
   ============================================================ */

.index {
  font-family:    var(--font-body);
  font-size:      var(--text-lead);        /* 12px */
  font-weight:    var(--weight-regular);
  line-height:    var(--lh-body);
  letter-spacing: var(--tracking-lead);
  text-transform: uppercase;
  color:          var(--color-text-muted); /* #424242 */
  white-space:    nowrap;
  flex-shrink:    0;
  margin:         0;
  padding-top:    6px;   /* optical cap-height alignment with 56px heading */
}


/* ============================================================
   CONTENT COLUMN — heading + body + what + image + results
   Figma: flex-col, flex-1, gap-64, items-start
   ============================================================ */

.contentCol {
  display:        flex;
  flex-direction: column;
  align-items:    flex-start;
  gap:            var(--gap-64);

  flex:           1 0 0;
  min-width:      0;
}


/* ============================================================
   HEADING
   Figma: Integral CF, 56px, tracking -0.84px, black uppercase
   ============================================================ */

.heading {
  font-family:    var(--font-display);
  font-size:      var(--text-h3);          /* 56px desktop */
  font-weight:    var(--weight-regular);
  line-height:    var(--lh-heading);
  letter-spacing: var(--tracking-h3);      /* -0.84px */
  text-transform: uppercase;
  color:          var(--color-primary);
  flex:           1 0 0;
  min-width:      0;
  margin:         0;
  white-space:    pre-wrap;
}


/* ============================================================
   BODY ROW — empty left spacer + right-aligned paragraph
   Figma: flex row, justify-between
   Left: flex-1 empty | Right: w-820px → para w-390px
   ============================================================ */

.bodyRow {
  display:         flex;
  justify-content: space-between;
  align-items:     flex-start;
  width:           100%;
}

/* Empty left spacer — pushes content right */
.bodySpacer {
  flex: 1 0 0;
}

/* Right column — fixed width matching Figma */
.bodyRight {
  width:      820px;
  max-width:  100%;
  flex-shrink: 0;
}

.bodyText {
  font-family:  var(--font-body);
  font-size:    14px;               /* Figma: B1 14px */
  font-weight:  var(--weight-regular);
  line-height:  var(--lh-body);     /* 20px */
  color:        var(--color-primary);
  width:        390px;              /* Figma: w-[390px] */
  max-width:    100%;
  margin:       0;
}


/* ============================================================
   WHAT I DESIGNED BLOCK
   Figma: flex-col, gap-24
   ============================================================ */

.whatBlock {
  display:        flex;
  flex-direction: column;
  gap:            var(--gap-24);
  width:          100%;
}

/* Label row: heading text (flex-1) + black extending line (flex-1) */
.whatLabelRow {
  display:     flex;
  align-items: center;
  gap:         var(--gap-24);
  width:       100%;
}

.whatLabel {
  font-family:    var(--font-display);
  font-size:      var(--text-h4);       /* 32px desktop */
  font-weight:    var(--weight-regular);
  line-height:    var(--lh-heading);
  letter-spacing: var(--tracking-h4);   /* 0 */
  text-transform: uppercase;
  color:          var(--color-primary);
  white-space:    nowrap;
  margin:         0;
  flex:           1 0 0;               /* Figma: flex-1, not shrink-0 */
}

/* Extending horizontal line — fills remaining label row width */
.whatLine {
  flex:             1 0 0;
  height:           1px;
  background-color: var(--color-primary);
}

/* Items wrapper — flex-wrap row, gap 24px (no longer CSS grid) */
.whatItems {
  display:   flex;
  flex-wrap: wrap;
  gap:       var(--gap-24);
  width:     100%;
}

/* Each item — divider + title (no star) */
.whatItem {
  display:        flex;
  flex-direction: column;
  align-items:    flex-start;
  flex:           1 0 0;            /* Figma: flex-1 per item */
  min-width:      180px;            /* prevent items from becoming too narrow */
}

.whatDivider {
  width:            100%;
  height:           1px;
  background-color: var(--color-tertiary);   /* #ccc */
  flex-shrink:      0;
}

.whatItemTitle {
  font-family:    var(--font-display);
  font-size:      var(--text-h5);       /* 20px desktop */
  font-weight:    var(--weight-regular);
  line-height:    var(--lh-heading);
  letter-spacing: var(--tracking-h5);   /* 0 */
  color:          var(--color-primary);
  margin:         0;
  padding-top:    8px;                  /* spacing between divider and title */
}


/* ============================================================
   IMAGE — full-width onboarding screenshot
   Figma: h-1056px (driven by image aspect), rounded-sm, w-full
   ============================================================ */

.imageWrap {
  position:      relative;
  width:         100%;
  aspect-ratio:  1312 / 1056;
  border-radius: var(--radius-sm);
  overflow:      hidden;
}

.image {
  object-fit: cover;
}


/* ============================================================
   RESULTS — label + large heading
   Figma: flex row, gap 24px
   ============================================================ */

.results {
  display:     flex;
  align-items: flex-start;
  gap:         var(--gap-24);
  width:       100%;
}

.resultsLabel {
  font-family:    var(--font-body);
  font-size:      var(--text-lead);        /* 12px — Lead typography */
  font-weight:    var(--weight-regular);
  line-height:    var(--lh-body);
  letter-spacing: var(--tracking-lead);
  color:          var(--color-primary);
  white-space:    nowrap;
  flex-shrink:    0;
  margin:         0;
}

.resultsHeading {
  font-family:    var(--font-body);
  font-size:      var(--text-lead);        /* 12px — Lead typography */
  font-weight:    var(--weight-regular);
  line-height:    var(--lh-body);
  letter-spacing: var(--tracking-lead);
  text-transform: uppercase;
  color:          var(--color-primary);
  flex:           1 0 0;
  min-width:      0;
  margin:         0;
  white-space:    pre-wrap;
}


/* ============================================================
   RESPONSIVE
   ============================================================ */

@media (max-width: 767px) {
  .root {
    padding-top:    var(--padding-40);
    padding-bottom: var(--padding-40);
  }

  /* Stack index above content on mobile */
  .row {
    flex-direction: column;
    gap:            var(--gap-16);
  }

  .index {
    padding-top: 0;
  }

  .contentCol {
    gap: var(--gap-40);
  }

  /* Body row: remove spacer, full-width paragraph */
  .bodyRow {
    flex-direction: column;
  }

  .bodySpacer {
    display: none;
  }

  .bodyRight {
    width: 100%;
  }

  .bodyText {
    width: 100%;
  }

  /* What label row: allow label to wrap */
  .whatLabel {
    white-space: normal;
  }

  /* What items: single column on mobile */
  .whatItems {
    flex-direction: column;
  }

  .whatItem {
    min-width: 0;
  }

  /* Image: auto height */
  .imageWrap {
    aspect-ratio: unset;
    height:       auto;
    min-height:   200px;
  }

  /* Results: stack vertically */
  .results {
    flex-direction: column;
    gap:            var(--gap-16);
  }
}

@media (min-width: 768px) and (max-width: 1023px) {
  .contentCol {
    width: 100%;
  }

  /* Body: spacer takes less space */
  .bodySpacer {
    flex: 0.4 0 0;
  }

  /* What items: wrap naturally on tablet */
  .whatItem {
    min-width: 200px;
  }
}
